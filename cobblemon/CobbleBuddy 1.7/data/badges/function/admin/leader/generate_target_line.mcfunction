# Generate the clickable selection line for the currently iterated player (@s)
# Mirrors the admin.id / generate_revoke_selection_line pattern, but keyed on the
# persistent database "player_ID" score so ANY online player can be picked as a Gym Leader.
execute if score @s player_ID matches 1 run tellraw @p[tag=temp.badge_viewer] [{"text":"• ","color":"gray"},{"selector":"@s","color":"aqua"},{"text":" [Select]","color":"green","clickEvent":{"action":"run_command","value":"/trigger badge_admin_target set 2"},"hoverEvent":{"action":"show_text","contents":[{"text":"Click to assign ","color":"yellow"},{"selector":"@s"},{"text":" as Gym Leader.","color":"yellow"}]}}]
